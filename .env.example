# Template for the local .env file. Copy and adjust:
#     cp .env.example .env
# The real .env is excluded from git via .gitignore.

# Mojang EULA (https://aka.ms/MinecraftEULA).
# Must be set to true, otherwise the server refuses to start.
EULA=false

# JVM heap size. Keep MAX_MEMORY below the host's available RAM
# (rule of thumb: host RAM minus ~1 GB).
INIT_MEMORY=1G
MAX_MEMORY=2G

# Timezone for log timestamps.
TZ=Europe/Berlin

# Port published on the host. Inside the container the server
# always listens on 25565.
HOST_PORT=8888
